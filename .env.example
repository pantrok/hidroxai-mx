# Copia a .env y completa. NO subir .env a Git (ya está en .gitignore).

# --- Cloudflare R2 (S3-compatible) para el remoto DVC ---
# El endpoint es https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://REEMPLAZA_ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=hidroxai-mx
# Token de API de R2 (S3): Access Key ID / Secret Access Key
AWS_ACCESS_KEY_ID=tu_access_key_id
AWS_SECRET_ACCESS_KEY=tu_secret_access_key
AWS_DEFAULT_REGION=auto

# --- DataMéxico (auxiliar; reconfirmar base tras migración 2026) ---
DATAMEXICO_API_BASE=https://api.datamexico.org/tesseract
